version = 1

; Router preset for llama-server.
; Mount host models at /models and select a section name via OpenAI "model".
; Constraint for this machine: keep shared GPU/RAM pressure <= 10 GiB.

[*]
; Lunar Lake Core Ultra 7 258V + Intel Arc 130V/140V integrated GPU.
; Single-user manager workload: latency and memory stability beat throughput slots.
parallel = 1
cache-ram = 0
threads = 8
threads-batch = 8
ubatch-size = 512
flash-attn = on
n-gpu-layers = 999
split-mode = none
main-gpu = 0
load-on-startup = false
stop-timeout = 20
timeout = 1200

; Default local profile: cap local GGUF experiments at 32k context.
; Practical VRAM/shared-GPU budget: <= 10 GiB. Do not expose 128k laptop profiles here; use api.ai.nixit.it for long context.
c = 32768

; Add real models below after downloading GGUF files into the model directory.
; Examples:
;
; [homelab-14b-q4-32k]
; model = /models/model-14b-q4.gguf
; c = 32768
;
; [fast-8b-q5-32k]
; model = /models/model-8b-q5.gguf
; c = 32768
;
; [large-32b-q4-32k]
; model = /models/model-32b-q4.gguf
; c = 32768

; 128k laptop profiles removed intentionally: they make prompt processing look hung
; and can push shared GPU memory above the 10 GiB budget.
; Use api.ai.nixit.it for long-context work.

[qwen3-4b-instruct-2507-ud-q6xl-32k]
model = /models/Qwen3-4B-Instruct-2507-UD-Q6_K_XL.gguf
c = 32768


[gemma4-e4b-it-ud-q8xl-32k]
model = /models/gemma-4-E4B-it-UD-Q8_K_XL.gguf
c = 32768
no-mmap = true
mlock = true

; Soren-1-Small — 1M context, 2B params Qwen3.5-based, F16 (no compression).
; Hybrid attention: 6/24 full-attention layers → KV cache ~6 GB with Q8_0.
; Total VRAM budget: ~3.8 GB weights + ~6 GB KV + ~1 GB overhead ≈ 10.8 GB.
; Needs --cache-type-k q8_0 --cache-type-v q8_0 (set via compose env vars).
[soren-1-small-f16-1m]
model = /models/Soren-1-Small-F16.gguf
c = 1048576
no-jinja = true
chat-template = chatml
