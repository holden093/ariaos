#!/usr/bin/env bash
set -euo pipefail

COMMAND="${1:-}"
LLAMA_PORT="${LLAMA_PORT:-8080}"
export LLAMA_PORT
MODEL_DIR="${MODEL_DIR:-/var/llms/ggufs}"
export MODEL_DIR

find_engine_dir() {
    if [ -n "${NIXIT_ENGINE_DIR:-}" ]; then
        printf '%s\n' "$NIXIT_ENGINE_DIR"
        return
    fi
    if [ -f /usr/share/nixit-gguf-engine/compose.yaml ]; then
        printf '%s\n' /usr/share/nixit-gguf-engine
        return
    fi
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local repo_engine
    repo_engine="$(cd "$script_dir/.." && pwd)/share/nixit-gguf-engine"
    if [ -f "$repo_engine/compose.yaml" ]; then
        printf '%s\n' "$repo_engine"
        return
    fi
    echo "❌ Motore GGUF non trovato: manca /usr/share/nixit-gguf-engine/compose.yaml" >&2
    exit 1
}

ENGINE_DIR="$(find_engine_dir)"
COMPOSE="$ENGINE_DIR/compose.yaml"
export NIXIT_ENGINE_DIR="$ENGINE_DIR"
MODELS_CONFIG="${MODELS_CONFIG:-$ENGINE_DIR/config/models.config}"
export MODELS_CONFIG
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/nixit-gguf-engine"
OVERRIDE="$STATE_DIR/compose.override.yaml"

compose_cmd() {
    if [ -f "$OVERRIDE" ]; then
        podman compose -f "$COMPOSE" -f "$OVERRIDE" "$@"
    else
        podman compose -f "$COMPOSE" "$@"
    fi
}

case "$COMMAND" in
    up)
        mkdir -p "$STATE_DIR" "$MODEL_DIR"
        echo "==> Analisi hardware per NixitOS GGUF engine..."
        if lsmod | grep -q "^nvidia_uvm"; then
            echo "    🌟 eGPU NVIDIA rilevata. Uso profilo CUDA."
            cat > "$OVERRIDE" <<'OVERRIDE'
services:
  gguf-engine:
    image: localhost/nixit-gguf-engine-cuda:latest
    build:
      context: ${NIXIT_ENGINE_DIR:-/usr/share/nixit-gguf-engine}
      dockerfile: Containerfile.cuda
    environment:
      ONEAPI_DEVICE_SELECTOR: ""
    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]
OVERRIDE
            compose_cmd up -d --build
        else
            echo "    🚀 eGPU non rilevata. Uso Intel Arc/SYCL."
            rm -f "$OVERRIDE"
            compose_cmd up -d --build
        fi
        echo "✅ Motore GGUF in esecuzione su http://127.0.0.1:${LLAMA_PORT}"
        ;;
    down)
        compose_cmd down
        ;;
    logs)
        podman logs -f nixit-gguf-engine
        ;;
    health)
        curl -fsS "http://127.0.0.1:${LLAMA_PORT}/health"
        echo -e "\n✅ Motore GGUF in ascolto."
        ;;
    models)
        curl -fsS "http://127.0.0.1:${LLAMA_PORT}/v1/models"
        echo
        ;;
    download)
        REPO="${2:-}"
        FILE="${3:-}"
        if [ -z "$REPO" ] || [ -z "$FILE" ]; then
            echo "Uso: nixitos-llm download <hf_repo> <filename>"
            exit 1
        fi
        echo "==> Scaricamento di $FILE da $REPO a $MODEL_DIR..."
        mkdir -p "$MODEL_DIR"
        podman run --rm -it -v "${MODEL_DIR}:/models:Z" docker.io/python:3.11-slim bash -c "\
            pip install -q huggingface_hub[cli] && \
            huggingface-cli download '$REPO' '$FILE' --local-dir /models --local-dir-use-symlinks False"
        echo "✅ Download completato in $MODEL_DIR"
        ;;
    *)
        echo "Uso: nixitos-llm {up|down|logs|health|models|download}"
        exit 1
        ;;
esac
