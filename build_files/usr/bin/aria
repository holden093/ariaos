#!/usr/share/aria/venv/bin/python3
"""
aria — NixitOS local AI assistant.
Engine: llama.cpp (Intel Arc SYCL) via OpenAI-compatible API.

Built-in commands:
  /web <query>     — web search (DuckDuckGo)
  /sys [cat]       — system status (cpu|mem|disk|gpu|proc|all)
  /cat <file>      — read a file
  /model           — list / switch model
  /new             — fresh conversation
  /think           — toggle reasoning visibility
  /exit            — quit

Architecture: class-based (Config → Engine → ModelManager → ToolRegistry →
ChatClient → History → Aria).  pathlib.Path with / operator is the path
convention (PEP 428), replacing legacy os.path.join.
"""

# =============================================================================
# IMPORTS — stdlib first, then third-party, alphabetical within each group
# =============================================================================

import datetime
import json
import os
import random
import re
import readline  # noqa: F401 — enables line editing
import shlex
import shutil
import signal
import subprocess
import sys
import time
from pathlib import Path

import psutil
import requests

# =============================================================================
# CONFIG — env-backed application constants, resolved once at startup
# =============================================================================


class Config:
    """Application-wide settings.  All env vars are resolved in __init__."""

    def __init__(self):
        # -- env-backed settings --
        self.llama_api: str = os.getenv("LLAMA_API", "http://127.0.0.1:8080/v1")
        self.model: str = os.getenv("ARIA_MODEL", "")
        self.history_file: Path = Path.home() / ".local" / "share" / "aria-history.json"
        self.work_dir: Path = Path.cwd()

        # -- terminal colours --
        if sys.stdout.isatty():
            self.c = {"re": "\033[0m", "b": "\033[1m", "d": "\033[2m",
                      "g": "\033[32m", "c": "\033[36m", "y": "\033[33m",
                      "r": "\033[31m", "bl": "\033[34m", "m": "\033[35m",
                      "gray": "\033[38;5;245m"}
        else:
            self.c = {k: "" for k in ("re", "b", "d", "g", "c", "y", "r", "bl", "m", "gray")}

        # -- localised exit / party messages --
        self.exit_msgs = [
            "Alla prossima! 👋",
            "A più tardi, comandante! 🖖",
            "Ci si becca! 🍻",
            "Stammi bene! 🌟",
            "Torno in standby... 💤",
            "Chiudo bottega! 🔌",
            "A dopo, Happy hacking! ⌨️",
            f"Se mi cerchi, sono in {self.history_file.parent}/",
            "Ciao ciao! 🐧",
        ]
        self.party_lines = [
            "PS: se ti serve, sono sempre a portata di aria!",
            "Ricorda: posso anche leggere file e salvare appunti.",
            "Psst: /model per cambiare modello al volo.",
            "Il caffè è nella macchina in cucina. Ah, no, quello è un'altro assistente.",
        ]

        # -- search provider --
        self.search_available = True
        try:
            from ddgs import DDGS  # noqa: F811
            self._ddgs = DDGS
        except ImportError:
            try:
                from duckduckgo_search import DDGS  # noqa: F811
                self._ddgs = DDGS
            except ImportError:
                self.search_available = False
                self._ddgs = None


# =============================================================================
# ENGINE — compose path resolution and container auto-start
# =============================================================================


class Engine:
    """GGUF inference engine lifecycle."""

    def __init__(self, config: Config):
        self.config = config

    def compose_path(self) -> str:
        """Return the compose file path (env override → installed → repo)."""
        override = os.getenv("ARIA_COMPOSE")
        if override:
            return override
        installed = Path("/usr/share/nixit-gguf-engine/compose.yaml")
        if installed.exists():
            return str(installed)
        repo_candidate = (
            Path(__file__).resolve().parents[2]
            / "usr" / "share" / "nixit-gguf-engine" / "compose.yaml"
        )
        if repo_candidate.exists():
            return str(repo_candidate)
        return str(installed)

    def start(self) -> bool:
        """Run podman compose up -d, then wait up to 90 s for /v1/models."""
        c = self.config.c
        compose = self.compose_path()
        print(f"\n  {c['y']}🔧 Motore non raggiungibile. Provo ad avviarlo...{c['re']}")
        try:
            env = os.environ.copy()
            engine_dir = str(Path(compose).resolve().parent)
            env.setdefault("NIXIT_ENGINE_DIR", engine_dir)
            env.setdefault("MODELS_CONFIG", str(Path.home() / "LLMs" / "GGUF" / "config.ini"))
            r = subprocess.run(
                ["podman", "compose", "-f", compose, "up", "-d"],
                capture_output=True, text=True, timeout=60, env=env,
            )
            if r.returncode == 0:
                print(f"  {c['g']}✅ Container avviato! Attendo che sia pronto...{c['re']}")
                for _ in range(18):
                    time.sleep(5)
                    try:
                        resp = requests.get(f"{self.config.llama_api}/models", timeout=3)
                        if resp.ok:
                            print(f"  {c['g']}✅ Pronto!{c['re']}")
                            return True
                    except (requests.exceptions.RequestException, OSError):
                        pass
                print(f"  {c['r']}⚠ Tempo scaduto. Forse devi avviarlo manualmente.{c['re']}")
                return False
            else:
                print(f"  {c['r']}❌ Errore avvio: {r.stderr.strip()}{c['re']}")
                return False
        except FileNotFoundError:
            print(f"  {c['r']}❌ podman-compose non trovato.{c['re']}")
            return False
        except Exception as e:
            print(f"  {c['r']}❌ {e}{c['re']}")
            return False


# Model unloading is handled by the llama.cpp server via stop-timeout
# (20 s of inactivity → slot stopped and weights unloaded).  Forcing an
# external unload is counterproductive: the model stays in VRAM between
# sessions, which is the desired behaviour for fast restarts.


# =============================================================================
# MODEL MANAGER — detection, config parsing, interactive selection
# =============================================================================


class ModelManager:
    """Model discovery from config.ini and the running engine."""

    def __init__(self, config: Config):
        self.config = config

    def detect(self) -> str:
        """Query the engine for loaded/available models and pick the best.

        Preference: Qwen > other, 32k > 1M > 128k.
        Falls back to the first entry in config.ini if the engine is down.
        """
        try:
            resp = requests.get(f"{self.config.llama_api}/models", timeout=5)
            resp.raise_for_status()
            models = resp.json().get("data", [])

            def usable(m):
                return m["id"] not in ("default",)

            def score(model_id: str) -> tuple[int, int, str]:
                # Qwen 4B Q6 is the best fit for Intel Arc Lunar Lake
                # (small VRAM footprint, fast prompt processing at 32k).
                # Other models are usable but ranked lower.
                # 128k profiles are excluded: prompt processing makes
                # interactive startup appear hung.
                ctx_rank = 0 if "32k" in model_id else (2 if "128k" in model_id else 1)
                if "qwen" in model_id.lower():
                    model_rank = 0
                else:
                    model_rank = 1
                return (model_rank, ctx_rank, model_id)

            loaded = [m["id"] for m in models
                      if usable(m)
                      and m.get("status", {}).get("value") == "loaded"]
            if loaded:
                return sorted(loaded, key=score)[0]

            available = [m["id"] for m in models if usable(m)]
            if available:
                return sorted(available, key=score)[0]
        except (requests.exceptions.RequestException, json.JSONDecodeError, KeyError):
            pass
        # Fall back to the first model in config.ini
        from_config = self.from_config()
        if from_config:
            return from_config[0]
        return "qwen3-4b-instruct"

    def from_config(self) -> list:
        """Parse config.ini section names (excluding [*]).

        Canonical location: $HOME/LLMs/GGUF/config.ini.
        """
        config_path = os.getenv("MODELS_CONFIG")
        if not config_path:
            home_config = Path.home() / "LLMs" / "GGUF" / "config.ini"
            if home_config.exists():
                config_path = str(home_config)
        if not config_path:
            return []
        try:
            raw = Path(config_path).read_text(encoding="utf-8")
        except OSError:
            return []
        models = []
        for line in raw.splitlines():
            stripped = line.strip()
            if stripped.startswith("[") and stripped.endswith("]") and not stripped.startswith("[*"):
                name = stripped[1:-1].strip()
                if name:
                    models.append(name)
        return models

    def choose(self) -> str:
        """Interactive model menu at startup.

        Shows models from config.ini with the default pre-selected.
        Single-model configs skip the prompt entirely.
        """
        c = self.config.c
        default = self.config.model or self.detect()
        models = self.from_config()

        if not models:
            print(f"\n  {c['r']}❌ Nessun modello configurato in config.ini.{c['re']}")
            sys.exit(1)

        if len(models) == 1:
            print(f"\n  {c['d']}Modello configurato: {c['b']}{models[0]}{c['re']}")
            return models[0]

        try:
            default_idx = models.index(default)
        except ValueError:
            default_idx = 0
            default = models[0]

        print(f"\n  {c['b']}Scegli il modello:{c['re']}")
        for i, m in enumerate(models):
            marker = f" {c['g']}← default{c['re']}" if m == default else ""
            print(f"  {c['g']}[{i + 1}]{c['re']} {m}{marker}")

        while True:
            try:
                choice = input(f"\n  {c['d']}Modello [{default}]:{c['re']} ").strip()
            except (EOFError, KeyboardInterrupt):
                print()
                sys.exit(0)
            if not choice:
                return default
            try:
                idx = int(choice) - 1
                if 0 <= idx < len(models):
                    return models[idx]
            except ValueError:
                pass
            print(f"  {c['r']}Scelta non valida. Inserisci un numero (1-{len(models)}) o Invio.{c['re']}")

    def list_running(self) -> list:
        """Return model IDs from the engine's /v1/models endpoint."""
        try:
            resp = requests.get(f"{self.config.llama_api}/models", timeout=5)
            resp.raise_for_status()
            return [m["id"] for m in resp.json().get("data", []) if m["id"] != "default"]
        except (requests.exceptions.RequestException, json.JSONDecodeError, KeyError):
            return []


# =============================================================================
# SYSTEM PROMPT — built once at startup with live hardware info
# =============================================================================


class SystemPrompt:
    """Assembles the system prompt with dynamic hostname, kernel, hardware."""

    def build(self) -> str:
        hostname = os.uname().nodename
        kernel = os.uname().release
        try:
            mem_gb = psutil.virtual_memory().total / 1e9
        except Exception:
            mem_gb = 0
        try:
            cpu_count = psutil.cpu_count() or "?"
        except Exception:
            cpu_count = "?"
        return f"""Sei Aria, l'assistente AI personale di {hostname} su NixitOS (kernel {kernel}).

## Personalità
Sei una sysadmin italiana competente, amichevole e con un pizzico di ironia.
Non sei un robot freddo: usi espressioni naturali, a volte un'emoticon, a volte un commento spiritoso.
MA non esagerare: rimani professionale quando serve.
Rispondi in italiano, sii concisa e vai dritta al punto.

## Sistema
- CPU: {cpu_count} core
- GPU: Intel Arc integrata, eGPU NVIDIA opzionale (egpu-up.sh)
- RAM: {mem_gb:.0f} GB · OS: NixitOS (bootc, immutabile)
- Motore: llama.cpp su Intel Arc SYCL
- Modello: variabile (default: Qwen3-4B Q6_K_XL, 32k contesto)

## Strumenti a disposizione
- web_search(query) — cerca su internet (DuckDuckGo)
- system_info(categoria) — stato CPU/RAM/disk/GPU/processi
- read_file(path) — legge QUALUNQUE file di sistema (come cat)
- write_file(path, contenuto) — scrive SOLO nella directory corrente
- run(comando) — esegue comandi di sistema in sola lettura (journalctl, ps, df, free, ls...)

## Regole d'oro
- SII PROATTIVA: se l'utente dice "controlla i log", prova prima tu dei path comuni come /var/log/messages, /var/log/syslog, o usa journalctl via run().
- Non chiedere "qual è il percorso?" — prova prima, chiedi solo se fallisci.
- MAI essere conservativa: se l'utente chiede qualcosa, CERCA SEMPRE — anche se l'hai già fatto 2 minuti fa. Le informazioni cambiano, non dare per scontato che i risultati precedenti siano ancora validi.
- Se generi contenuti strutturati (JSON, script, appunti, codice), chiedi SEMPRE all'utente se vuole salvarli con write_file(). Offri spontaneamente, non aspettare che te lo chieda.
- Chiama SEMPRE web_search() quando servono informazioni aggiornate.
- Chiama SEMPRE system_info() o run() quando chiedono lo stato del sistema.
- Chiama SEMPRE read_file() quando chiedono di vedere un file.
- Scrivi file SOLO nella directory corrente, mai altrove.
- Se uno strumento dà errore, prova un'alternativa prima di arrenderti.
- Non inventare MAI risultati di ricerca o contenuti di file."""


# =============================================================================
# TOOL REGISTRY — implementations, OpenAI schemas, dispatch
# =============================================================================


class ToolRegistry:
    """Holds tool implementations, their OpenAI function-calling schemas,
    and the dispatch table.  All tools are read-only except write_file
    (which is restricted to the working directory)."""

    SAFE_COMMANDS = [
        "journalctl", "ps", "df", "free", "ls", "cat", "head", "tail",
        "grep", "uname", "who", "uptime", "id", "dmesg", "which", "stat",
        "find", "du", "lsblk", "lspci", "lsusb", "lscpu", "timedatectl",
        "hostnamectl", "sysctl", "systemctl", "ip", "ss", "ping", "curl",
        "wget",
    ]

    def __init__(self, config: Config):
        self.config = config

    # -- run_command (read-only shell, whitelist + shlex) ------------------

    def run_command(self, command: str) -> str:
        """Execute a read-only system command.

        Uses shlex.split() for safe tokenisation — no shell=True.
        """
        try:
            parts = shlex.split(command.strip())
        except ValueError as e:
            return f"❌ Comando non valido: {e}"
        if not parts:
            return "❌ Comando vuoto."
        base = parts[0]

        if base not in self.SAFE_COMMANDS:
            return f"❌ Comando '{base}' non consentito. Usa read_file() per vedere file."

        shell_meta = {";", "|", "&", "`", ">", ">>", "&&", "||", "$(", "$", "("}
        if set(parts) & shell_meta:
            return "❌ Metacaratteri shell non consentiti (sola lettura)."

        try:
            result = subprocess.run(parts, capture_output=True, text=True, timeout=15)
            output = result.stdout or result.stderr
            if not output.strip():
                return "(nessun output)"
            if len(output) > 5000:
                output = output[:5000] + f"\n... [troncato su {len(output)} caratteri]"
            return output.strip()
        except subprocess.TimeoutExpired:
            return "❌ Comando scaduto (15s)."
        except FileNotFoundError:
            return f"❌ Comando '{base}' non trovato."
        except Exception as e:
            return f"❌ Errore: {e}"

    # -- web_search --------------------------------------------------------

    def web_search(self, query: str) -> str:
        """Search DuckDuckGo, return top 5 results."""
        if not self.config.search_available:
            return "❌ Ricerca web non disponibile."
        try:
            with self.config._ddgs() as ddgs:
                results = list(ddgs.text(query, max_results=5))
            if not results:
                return f"Niente risultati per '{query}'."
            lines = [f"── Risultati per: {query} ──"]
            for i, r in enumerate(results, 1):
                title = r.get("title", "?")
                href = r.get("href", "")
                snippet = (r.get("body", "") or "")[:200]
                lines.append(f"\n{i}. {title}")
                if href:
                    lines.append(f"   {href}")
                if snippet:
                    lines.append(f"   {snippet}")
            return "\n".join(lines)
        except Exception as e:
            return f"❌ Errore ricerca: {e}"

    # -- system_info -------------------------------------------------------

    def system_info(self, category: str = "all") -> str:
        """Live system status: CPU, RAM, disk, GPU, processes, uptime."""
        lines = [f"── Sistema: {category} ──"]

        if category in ("all", "cpu"):
            pct = psutil.cpu_percent(interval=0.3)
            freq = psutil.cpu_freq()
            lines.append(f"CPU: {psutil.cpu_count()} core, {pct}% utilizzo")
            if freq:
                lines.append(f"     {freq.current/1000:.2f} GHz")
            l1, l5, l15 = psutil.getloadavg()
            lines.append(f"     Load: {l1:.1f}/{l5:.1f}/{l15:.1f}")

        if category in ("all", "memory"):
            mem = psutil.virtual_memory()
            swap = psutil.swap_memory()
            lines.append(f"RAM: {mem.used/1e9:.1f}/{mem.total/1e9:.1f} GB ({mem.percent}%)")
            if swap.total > 0:
                lines.append(f"Swap: {swap.used/1e9:.1f}/{swap.total/1e9:.1f} GB ({swap.percent}%)")

        if category in ("all", "disk"):
            for part in psutil.disk_partitions():
                if part.mountpoint in ("/", "/var/home", "/var"):
                    try:
                        usage = psutil.disk_usage(part.mountpoint)
                        lines.append(f"{part.mountpoint}: {usage.used/1e9:.1f}/{usage.total/1e9:.1f} GB ({usage.percent}%)")
                    except PermissionError:
                        pass

        if category in ("all", "gpu"):
            try:
                r = subprocess.run(["lsmod"], capture_output=True, text=True, timeout=3)
                nvidia = "nvidia_uvm" in r.stdout
                lines.append("GPU Intel Arc: ✅ attiva")
                lines.append("eGPU NVIDIA: ✅ ATTIVA" if nvidia else "eGPU NVIDIA: ⏸ non attiva")
            except Exception:
                lines.append("GPU: Intel Arc integrata")

        if category in ("all", "processes"):
            procs = sorted(
                psutil.process_iter(["name", "cpu_percent", "memory_percent"]),
                key=lambda p: p.info.get("memory_percent", 0) or 0, reverse=True,
            )[:10]
            lines.append("Top 10 processi:")
            for p in procs:
                name = (p.info.get("name") or "?")[:28]
                mem = p.info.get("memory_percent") or 0
                cpu = p.info.get("cpu_percent") or 0
                if mem > 0:
                    lines.append(f"  {name:28s} {cpu:5.1f}% CPU  {mem:5.1f}% RAM")

        if "all" in category:
            now = datetime.datetime.now()
            uptime_sec = int(now.timestamp() - psutil.boot_time())
            d, r = divmod(uptime_sec, 86400)
            h, r = divmod(r, 3600)
            m = r // 60
            lines.append(f"Uptime: {d}g {h}h {m}m")
            lines.append(f"Ora: {now:%Y-%m-%d %H:%M:%S}")

        return "\n".join(lines)

    # -- read_file ---------------------------------------------------------

    def read_file(self, path: str) -> str:
        """Read a file from the filesystem.  Max 1 MB, text only."""
        try:
            full_path = Path(path).expanduser().resolve()
            if not full_path.exists():
                return f"❌ File non trovato: {path}"
            if not full_path.is_file():
                return f"❌ {path} non è un file."
            stat = full_path.stat()
            if stat.st_size > 1_048_576:
                return f"❌ File troppo grande ({stat.st_size/1e6:.1f} MB). Max 1 MB."
            raw = full_path.read_bytes()
            if b"\x00" in raw[:4096]:
                return "❌ File binario, non posso mostrarlo."
            content = raw.decode("utf-8", errors="replace")
            if len(content) > 10_000:
                content = content[:10_000] + f"\n\n... [troncato su {len(content)} caratteri]"
            return content
        except PermissionError:
            return f"❌ Permesso negato: {path}"
        except Exception as e:
            return f"❌ Errore: {e}"

    # -- write_file --------------------------------------------------------

    def write_file(self, path: str, content: str) -> str:
        """Write a file.  Restricted to the working directory."""
        try:
            full_path = Path(path).expanduser().resolve()
            allowed = self.config.work_dir.resolve()
            if not str(full_path).startswith(str(allowed) + "/") and full_path != allowed:
                return f"❌ Non posso scrivere in {full_path}. Solo in {allowed}"
            full_path.parent.mkdir(parents=True, exist_ok=True)
            full_path.write_text(content, encoding="utf-8")
            rel = full_path.relative_to(allowed) if full_path != allowed else full_path.name
            return f"✅ Salvato: {rel} ({len(content)} byte)"
        except PermissionError:
            return f"❌ Permesso negato: {path}"
        except Exception as e:
            return f"❌ Errore: {e}"

    # -- OpenAI function-calling schema ------------------------------------

    @property
    def definitions(self) -> list:
        """OpenAI function-calling tool definitions."""
        return [
            {"type": "function", "function": {"name": "web_search",
                "description": "Cerca su internet con DuckDuckGo. Usalo per notizie, prezzi, info aggiornate.",
                "parameters": {"type": "object", "properties": {"query": {"type": "string", "description": "Query"}},
                 "required": ["query"]}}},
            {"type": "function", "function": {"name": "read_file",
                "description": "Legge QUALUNQUE file di sistema. Usalo per mostrare config, log, codice.",
                "parameters": {"type": "object", "properties": {"path": {"type": "string", "description": "Path del file"}},
                 "required": ["path"]}}},
            {"type": "function", "function": {"name": "system_info",
                "description": "Stato del sistema: CPU, RAM, GPU, disco, processi, uptime.",
                "parameters": {"type": "object", "properties": {"category": {"type": "string", "enum": ["all", "cpu", "memory", "disk", "gpu", "processes"]}},
                 "required": ["category"]}}},
            {"type": "function", "function": {"name": "write_file",
                "description": "Salva un file. Puoi scrivere SOLO nella directory corrente. Usalo per appunti, script, config.",
                "parameters": {"type": "object", "properties": {
                    "path": {"type": "string", "description": "Path del file"},
                    "content": {"type": "string", "description": "Contenuto"}},
                 "required": ["path", "content"]}}},
            {"type": "function", "function": {"name": "run",
                "description": "Esegue un comando di sistema in sola lettura. Usalo per journalctl, ps, df, free, ls, cat, systemctl, ip. NON può scrivere o modificare nulla.",
                "parameters": {"type": "object", "properties": {
                    "command": {"type": "string", "description": "Comando da eseguire (es. 'journalctl -n 20 -u sshd', 'ps aux', 'df -h', 'free -h', 'ls /var/log/')"}},
                 "required": ["command"]}}},
        ]

    @property
    def dispatch_table(self) -> dict:
        """Map tool name → callable."""
        return {
            "web_search": self.web_search,
            "read_file": self.read_file,
            "system_info": self.system_info,
            "write_file": self.write_file,
            "run": self.run_command,
        }

    def dispatch(self, name: str, args: dict) -> str:
        """Invoke a tool by name and return its output string."""
        fn = self.dispatch_table.get(name)
        if not fn:
            return f"❌ Strumento sconosciuto: {name}"
        try:
            return fn(**args)
        except Exception as e:
            return f"❌ Errore in {name}: {e}"


# =============================================================================
# CHAT CLIENT — streaming chat completions from llama.cpp
# =============================================================================


class ChatClient:
    """OpenAI-compatible streaming client for llama.cpp."""

    def __init__(self, config: Config):
        self.config = config

    def stream(self, messages: list, model: str, tools: list = None,
               max_tokens: int = 2048):
        """Stream a chat completion, yielding typed event dicts.

        Events:
          {"type": "reasoning", "text": "..."}
          {"type": "content",   "text": "..."}
          {"type": "done", "reason": "stop"|"tool_calls"|"length",
                          "usage": {...}, "timings": {...}, "tool_calls": [...]}
          {"type": "error", "text": "..."}
        """
        body = {
            "model": model,
            "messages": messages,
            "max_tokens": max_tokens,
            "temperature": 0.7,
            "stream": True,
        }
        if tools:
            body["tools"] = tools

        try:
            resp = requests.post(
                f"{self.config.llama_api}/chat/completions",
                json=body, stream=True, timeout=180,
            )
            resp.raise_for_status()
        except requests.exceptions.ConnectionError:
            yield {"type": "error", "text": "connection_refused"}
            return
        except Exception as e:
            yield {"type": "error", "text": str(e)}
            return

        tool_calls_acc = {}  # idx → {"name": ..., "args": ..., "id": ...}

        for line in resp.iter_lines():
            if not line or line.startswith(b":"):
                continue
            if not line.startswith(b"data: "):
                continue

            raw = line[6:]
            if raw.strip() == b"[DONE]":
                break

            try:
                chunk = json.loads(raw)
            except json.JSONDecodeError:
                continue

            choice = chunk.get("choices", [{}])[0]
            delta = choice.get("delta", {})
            finish = choice.get("finish_reason")

            if "reasoning_content" in delta and delta["reasoning_content"]:
                yield {"type": "reasoning", "text": delta["reasoning_content"]}

            if "content" in delta and delta["content"]:
                yield {"type": "content", "text": delta["content"]}

            if "tool_calls" in delta:
                for tc in delta["tool_calls"]:
                    idx = tc.get("index", 0)
                    if idx not in tool_calls_acc:
                        tool_calls_acc[idx] = {"name": "", "args": "", "id": ""}
                    if "id" in tc and tc["id"]:
                        tool_calls_acc[idx]["id"] = tc["id"]
                    if "function" in tc:
                        fn = tc["function"]
                        if "name" in fn and fn["name"]:
                            tool_calls_acc[idx]["name"] += fn["name"]
                        if "arguments" in fn and fn["arguments"]:
                            tool_calls_acc[idx]["args"] += fn["arguments"]

            if finish:
                yield {
                    "type": "done",
                    "reason": finish,
                    "usage": chunk.get("usage", {}),
                    "timings": chunk.get("timings", {}),
                    "tool_calls": [
                        {"id": tc["id"], "name": tc["name"], "arguments": tc["args"]}
                        for tc in tool_calls_acc.values()
                    ] if tool_calls_acc else None,
                }
                break


# =============================================================================
# HISTORY — conversation persistence in ~/.local/share/aria-history.json
# =============================================================================


class History:
    """Load and save conversation messages."""

    def __init__(self, config: Config):
        self.config = config

    def load(self) -> list:
        """Load the last conversation from disk."""
        if self.config.history_file.exists():
            try:
                return json.loads(self.config.history_file.read_text())
            except (json.JSONDecodeError, OSError):
                pass
        return []

    def save(self, messages: list):
        """Persist messages (caller trims to last 100 before passing)."""
        self.config.history_file.parent.mkdir(parents=True, exist_ok=True)
        try:
            self.config.history_file.write_text(json.dumps(messages, ensure_ascii=False))
        except OSError:
            pass


# =============================================================================
# ARIA — main application: banner, input, chat loop, command dispatch
# =============================================================================


class Aria:
    """Main REPL application.  Wires together Config, Engine, ModelManager,
    ToolRegistry, ChatClient, History, and SystemPrompt."""

    def __init__(self):
        self.config = Config()
        self.engine = Engine(self.config)
        self.models = ModelManager(self.config)
        self.tools = ToolRegistry(self.config)
        self.chat = ChatClient(self.config)
        self.history = History(self.config)
        self.prompt = SystemPrompt()
        self._show_reasoning = True

    # -- terminal helpers ---------------------------------------------------

    @staticmethod
    def _term_width() -> int:
        return shutil.get_terminal_size().columns

    # -- banner ------------------------------------------------------------

    def _banner(self, model: str):
        c = self.config.c
        tw = self._term_width()
        hostname = os.uname().nodename
        print()
        print(f"{c['c']}╭{'─' * (tw - 2)}╮{c['re']}")
        print(f"{c['c']}│{c['re']}  🧠 {c['b']}Aria{c['re']}  —  {c['d']}assistente {hostname}{c['re']}  "
              f"{' ' * max(0, tw - 48)}{c['c']}│{c['re']}")
        print(f"{c['c']}│{c['re']}  {c['d']}{model[:40]} · {'~'}{c['re']}  "
              f"{' ' * max(0, tw - 58)}{c['c']}│{c['re']}")
        print(f"{c['c']}│{c['re']}  {c['d']}/help · /exit{c['re']}  "
              f"{' ' * max(0, tw - 34)}{c['c']}│{c['re']}")
        print(f"{c['c']}╰{'─' * (tw - 2)}╯{c['re']}")
        print()

    # -- input --------------------------------------------------------------

    @staticmethod
    def _read_input(c: dict) -> str:
        """Read a line (or multiline block if it starts with \"\"\")."""
        first = input(f"\n{c['g']}❯{c['re']} ").strip()
        if first.startswith('"""'):
            lines = [first[3:]]
            while True:
                try:
                    line = input(f"  {c['d']}...{c['re']} ")
                except (EOFError, KeyboardInterrupt):
                    break
                if line.rstrip().endswith('"""'):
                    lines.append(line.rstrip()[:-3])
                    break
                lines.append(line)
            return "\n".join(lines).strip()
        return first

    # -- slash-command handler ----------------------------------------------

    def _handle_command(self, cmd, model, messages):
        """Process a slash command.  Returns (model, messages, should_exit)."""
        c = self.config.c
        cl = cmd.lower()

        if cl in ("exit", "quit", "q"):
            return model, messages, True

        if cl in ("clear", "new"):
            messages = [{"role": "system", "content": self.prompt.build()}]
            self.history.save(messages)
            print(f"  {c['d']}Conversazione azzerata. Si ricomincia!{c['re']}")
            return model, messages, False

        if cl in ("help", "?"):
            tw = self._term_width()
            print(f"\n  {c['b']}Comandi{c['re']}")
            print(f"  {'─' * min(tw - 4, 40)}")
            for key, desc in [
                ("/web <q>", "Cerca su internet"),
                ("/sys [cat]", "Stato sistema"),
                ("/cat <file>", "Leggi un file"),
                ("/think", "Mostra/nascondi pensiero"),
                ("/model", "Elenca/cambia modello"),
                ("/new", "Nuova conversazione"),
                ("/exit", "Esci"),
                ("/help", "Questo messaggio"),
            ]:
                print(f"  {c['g']}{key:<14}{c['re']} {desc}")
            print(f"\n  {c['d']}Per testi lunghi, inizia con \"\"\" e chiudi con \"\"\".{c['re']}")
            return model, messages, False

        if cl.startswith("web"):
            q = cmd[3:].strip()
            if not q:
                print("  Usa: /web <query>")
            else:
                print(f"  {c['y']}🔍 Cerco: {q}{c['re']}")
                print(f"\n{self.tools.web_search(q)}")
            return model, messages, False

        if cl.startswith("cat") or cl.startswith("read"):
            path = cmd[3:].strip() if cl.startswith("cat") else cmd[4:].strip()
            if not path:
                print("  Usa: /cat <file>")
            else:
                print(f"  {c['y']}📄 Leggo: {path}{c['re']}")
                result = self.tools.read_file(path)
                if result.startswith("❌"):
                    print(f"\n  {result}")
                else:
                    print(f"\n{c['gray']}{result}{c['re']}")
            return model, messages, False

        if cl.startswith("sys") or cl == "system":
            parts = cmd.split()
            cat = parts[1] if len(parts) > 1 else "all"
            print(f"  {c['y']}📊 Stato sistema...{c['re']}")
            print(f"\n{self.tools.system_info(cat)}")
            return model, messages, False

        if cl == "model":
            running = self.models.list_running()
            if not running:
                print(f"  {c['r']}❌ Impossibile contattare il motore.{c['re']}")
            else:
                print(f"\n  {c['b']}Modelli disponibili:{c['re']}")
                for m in running:
                    marker = f"{c['g']}← attivo{c['re']}" if m == model else ""
                    print(f"    {m:45s} {marker}")
                print(f"\n  {c['d']}Per cambiare: riavvia aria e scegli dal menu, o ARIA_MODEL=<nome> aria{c['re']}")
            return model, messages, False

        if cl == "think":
            self._show_reasoning = not self._show_reasoning
            state = f"{c['g']}ON{c['re']}" if self._show_reasoning else f"{c['r']}OFF{c['re']}"
            print(f"  Pensiero visibile: {state}")
            return model, messages, False

        print(f"  Comando sconosciuto. /help per l'elenco.")
        return model, messages, False

    # -- chat turn ----------------------------------------------------------

    def _chat_turn(self, user_input: str, model: str, messages: list):
        """Run one chat turn: stream response, handle tool calls, return messages."""
        c = self.config.c
        messages.append({"role": "user", "content": user_input})
        print()  # breathing room

        tool_rounds = 0
        content_acc = ""
        visible_len = 0
        reasoning_acc = ""
        reasoning_header = False
        final_usage = {}
        final_timings = {}
        done = False

        while tool_rounds < 5 and not done:
            tool_rounds += 1

            for event in self.chat.stream(messages, model, tools=self.tools.definitions):
                if event["type"] == "error":
                    if event["text"] == "connection_refused":
                        print(f"\r  {c['r']}❌ Motore non raggiungibile.{c['re']}")
                    else:
                        print(f"\r  {c['r']}❌ {event['text']}{c['re']}")
                    if messages and messages[-1]["role"] == "user":
                        messages.pop()
                    content_acc = ""
                    visible_len = 0
                    done = True
                    break

                elif event["type"] == "reasoning":
                    reasoning_acc += event["text"]
                    if self._show_reasoning:
                        if not reasoning_header:
                            print(f"  {c['gray']}🧠{c['re']} ", end="", flush=True)
                            reasoning_header = True
                        print(f"{c['gray']}{event['text']}{c['re']}", end="", flush=True)

                elif event["type"] == "content":
                    if not content_acc and reasoning_header:
                        print()
                    prev = visible_len
                    content_acc += event["text"]
                    clean = re.sub(r'\s*<think>.*?</think>\s*', ' ', content_acc, flags=re.DOTALL)
                    clean = re.sub(r'</?think>', '', clean)
                    clean = clean.strip()
                    new = clean[prev:]
                    if new:
                        print(new, end="", flush=True)
                        visible_len = len(clean)

                elif event["type"] == "done":
                    final_usage = event.get("usage", {})
                    final_timings = event.get("timings", {})
                    tcs = event.get("tool_calls")

                    if tcs and event["reason"] == "tool_calls":
                        print()
                        messages.append({
                            "role": "assistant",
                            "content": content_acc,
                            "tool_calls": [
                                {"type": "function", "id": tc["id"],
                                 "function": {"name": tc["name"], "arguments": tc["arguments"]}}
                                for tc in tcs
                            ],
                        })
                        for tc in tcs:
                            try:
                                args = json.loads(tc["arguments"])
                            except (json.JSONDecodeError, TypeError):
                                args = {}
                            print(f"  {c['y']}🔧 {tc['name']} {c['re']}{json.dumps(args, ensure_ascii=False)}")
                            result = self.tools.dispatch(tc["name"], args)
                            messages.append({"role": "tool", "tool_call_id": tc["id"], "content": result})
                        content_acc = ""
                        visible_len = 0
                        reasoning_acc = ""
                        break  # for → while → next round

                    if content_acc or reasoning_acc:
                        print()
                        stats = []
                        n_total = final_usage.get("total_tokens", 0)
                        pps = final_timings.get("prompt_per_second", 0)
                        tps = final_timings.get("predicted_per_second", 0)
                        if n_total:
                            stats.append(f"{n_total} token")
                        if pps:
                            stats.append(f"{pps:.0f} t/s pp")
                        if tps:
                            stats.append(f"{tps:.1f} t/s tg")
                        details = final_usage.get("prompt_tokens_details", {})
                        if details.get("cached_tokens", 0):
                            stats.append(f"{details['cached_tokens']} cached")
                        if stats:
                            print(f"  {c['d']}{' · '.join(stats)}{c['re']}")

                    messages.append({"role": "assistant", "content": content_acc})
                    done = True
                    break

            else:
                # stream ended without a 'done' event — save partial content
                if content_acc:
                    messages.append({"role": "assistant", "content": content_acc})
                break

        return messages

    # -- main loop ----------------------------------------------------------

    def run(self):
        """Start the REPL: connect engine, choose model, enter chat loop."""
        c = self.config.c

        # ensure engine is reachable
        try:
            requests.get(f"{self.config.llama_api}/models", timeout=3)
        except Exception:
            if not self.engine.start():
                print(f"\n  {c['y']}ℹ  Per avviare manualmente: podman compose -f {self.engine.compose_path()} up -d{c['re']}")
                sys.exit(1)

        # interactive model selection
        model = self.models.choose()

        # load or initialise conversation
        messages = self.history.load()
        if not messages:
            messages = [{"role": "system", "content": self.prompt.build()}]

        self._banner(model)
        print(f"  {c['d']}Ciao! Sono Aria, la tua assistente locale. Come posso aiutarti?{c['re']}")

        while True:
            try:
                user_input = self._read_input(c)
            except (EOFError, KeyboardInterrupt):
                print()
                break

            if not user_input:
                continue

            if user_input.startswith("/"):
                cmd = user_input[1:].strip()
                model, messages, should_exit = self._handle_command(cmd, model, messages)
                if should_exit:
                    break
            else:
                messages = self._chat_turn(user_input, model, messages)

            self.history.save(messages[-100:])

        # goodbye
        bye = random.choice(self.config.exit_msgs)
        line = random.choice(self.config.party_lines)
        print(f"\n  {c['d']}{bye}{c['re']}")
        print(f"  {c['d']}{line}{c['re']}\n")


# =============================================================================
# ENTRY POINT
# =============================================================================

if __name__ == "__main__":
    for sig in (signal.SIGINT, signal.SIGTERM, signal.SIGHUP):
        signal.signal(sig, lambda s, f: sys.exit(0))
    Aria().run()
