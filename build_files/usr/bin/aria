# ── Cronologia ──────────────────────────────
def load_history() -> list:
    if HISTORY_FILE.exists():
        try:
            return json.loads(HISTORY_FILE.read_text())
        except Exception:
            pass
    return []


def save_history(msgs: list):
    HISTORY_FILE.parent.mkdir(parents=True, exist_ok=True)
    try:
        HISTORY_FILE.write_text(json.dumps(msgs, ensure_ascii=False))
    except Exception:
        pass


# ── Chiamata API (streaming) ─────────────────
def call_llm_stream(messages: list, tools: list = None, max_tokens: int = 2048):
    """Stream response from llama.cpp, yielding event dicts.

    Yields:
      {"type": "reasoning", "text": "..."}  — token di pensiero
      {"type": "content",   "text": "..."}  — token di risposta
      {"type": "tool_call", "name": "...", "args": {...}}  — chiamata strumento
      {"type": "done", "reason": "stop"|"tool_calls"|"length",
                      "usage": {...}, "timings": {...}}  — fine
    """
    body = {
        "model": MODEL,
        "messages": messages,
        "max_tokens": max_tokens,
        "temperature": 0.7,
        "stream": True,
    }
    if tools:
        body["tools"] = tools

    try:
        resp = requests.post(f"{LLAMA_API}/chat/completions", json=body, stream=True, timeout=180)
        resp.raise_for_status()
    except requests.exceptions.ConnectionError:
        yield {"type": "error", "text": "connection_refused"}
        return
    except Exception as e:
        yield {"type": "error", "text": str(e)}
        return

    # Accumulatori per tool calling in streaming
    tool_calls_acc = {}  # idx → {"name": ..., "args": ..., "id": ...}

    for line in resp.iter_lines():
        if not line or line.startswith(b":"):
            continue
        if not line.startswith(b"data: "):
            continue

        raw = line[6:]
        if raw.strip() == b"[DONE]":
            break

        try:
            chunk = json.loads(raw)
        except json.JSONDecodeError:
            continue

        choice = chunk.get("choices", [{}])[0]
        delta = choice.get("delta", {})
        finish = choice.get("finish_reason")

        # Reasoning content (Gemma4 thinking)
        if "reasoning_content" in delta and delta["reasoning_content"]:
            yield {"type": "reasoning", "text": delta["reasoning_content"]}

        # Regular content
        if "content" in delta and delta["content"]:
            yield {"type": "content", "text": delta["content"]}

        # Tool calls in streaming mode
        if "tool_calls" in delta:
            for tc in delta["tool_calls"]:
                idx = tc.get("index", 0)
                if idx not in tool_calls_acc:
                    tool_calls_acc[idx] = {"name": "", "args": "", "id": ""}
                if "id" in tc and tc["id"]:
                    tool_calls_acc[idx]["id"] = tc["id"]
                if "function" in tc:
                    fn = tc["function"]
                    if "name" in fn and fn["name"]:
                        tool_calls_acc[idx]["name"] += fn["name"]
                    if "arguments" in fn and fn["arguments"]:
                        tool_calls_acc[idx]["args"] += fn["arguments"]

        # Fine — raccogli usage e timings
        if finish:
            usage = chunk.get("usage", {})
            timings = chunk.get("timings", {})
            yield {
                "type": "done",
                "reason": finish,
                "usage": usage,
                "timings": timings,
                "tool_calls": [
                    {"id": tc["id"], "name": tc["name"], "arguments": tc["args"]}
                    for tc in tool_calls_acc.values()
                ] if tool_calls_acc else None,
            }
            break


def run_tool(name: str, args: dict) -> str:
    fn = TOOL_IMPL.get(name)
    if not fn:
        return f"❌ Strumento sconosciuto: {name}"
    try:
        return fn(**args)
    except Exception as e:
        return f"❌ Errore in {name}: {e}"


# ── Input multilinea ────────────────────────
def read_multiline() -> str:
    """Legge input: se inizia con \"\"\", continua fino al \"\"\" di chiusura."""
    first = input(f"\n{C['g']}❯{C['re']} ").strip()
    if first.startswith('"""'):
        lines = [first[3:]]
        while True:
            try:
                line = input(f"  {C['d']}...{C['re']} ")
            except (EOFError, KeyboardInterrupt):
                break
            if line.rstrip().endswith('"""'):
                lines.append(line.rstrip()[:-3])
                break
            lines.append(line)
        return "\n".join(lines).strip()
    return first


# ── Interfaccia ─────────────────────────────
def t_width():
    return shutil.get_terminal_size().columns


def print_banner():
    tw = t_width()
    hostname = os.uname().nodename
    print()
    print(f"{C['c']}╭{'─' * (tw - 2)}╮{C['re']}")
    print(f"{C['c']}│{C['re']}  🧠 {C['b']}Aria{C['re']}  —  {C['d']}assistente {hostname}{C['re']}  "
          f"{' ' * max(0, tw - 48)}{C['c']}│{C['re']}")
    print(f"{C['c']}│{C['re']}  {C['d']}{MODEL[:40]} · {'~'}{C['re']}  "
          f"{' ' * max(0, tw - 58)}{C['c']}│{C['re']}")
    print(f"{C['c']}│{C['re']}  {C['d']}/help · /exit{C['re']}  "
          f"{' ' * max(0, tw - 34)}{C['c']}│{C['re']}")
    print(f"{C['c']}╰{'─' * (tw - 2)}╯{C['re']}")
    print()


def chat_loop():
    global MODEL
    show_reasoning = True  # /think per toggle

    # Controllo connessione motore
    try:
        requests.get(f"{LLAMA_API}/models", timeout=3)
    except Exception:
        if not try_start_engine():
            print(f"\n  {C['y']}ℹ  Per avviare manualmente: podman compose -f {default_compose_path()} up -d{C['re']}")
            sys.exit(1)

    # Menu interattivo: scegli il modello (default = Soren o ARIA_MODEL se impostato)
    MODEL = choose_model()

    messages = load_history()
    if not messages:
        messages = [{"role": "system", "content": get_system_prompt()}]

    print_banner()
    print(f"  {C['d']}Ciao! Sono Aria, la tua assistente locale. Come posso aiutarti?{C['re']}")

    while True:
        try:
            user_input = read_multiline()
        except (EOFError, KeyboardInterrupt):
            print()
            break

        if not user_input:
            continue

        # ── Comandi ──
        if user_input.startswith("/"):
            cmd = user_input[1:].strip()
            cl = cmd.lower()

            if cl in ("exit", "quit", "q"):
                break

            elif cl in ("clear", "new"):
                messages = [{"role": "system", "content": get_system_prompt()}]
                save_history(messages)
                print(f"  {C['d']}Conversazione azzerata. Si ricomincia!{C['re']}")
                continue

            elif cl in ("help", "?"):
                tw = t_width()
                print(f"\n  {C['b']}Comandi{C['re']}")
                print(f"  {'─' * min(tw - 4, 40)}")
                print(f"  {C['g']}/web <q>{C['re']}       Cerca su internet")
                print(f"  {C['g']}/sys [cat]{C['re']}     Stato sistema")
                print(f"  {C['g']}/cat <file>{C['re']}    Leggi un file")
                print(f"  {C['g']}/think{C['re']}          Mostra/nascondi pensiero")
                print(f"  {C['g']}/model{C['re']}          Elenca/cambia modello")
                print(f"  {C['g']}/new{C['re']}            Nuova conversazione")
                print(f"  {C['g']}/exit{C['re']}           Esci")
                print(f"  {C['g']}/help{C['re']}           Questo messaggio")
                print(f"\n  {C['d']}Per testi lunghi, inizia con \"\"\" e chiudi con \"\"\".{C['re']}")
                continue

            elif cl.startswith("web"):
                q = cmd[3:].strip()
                if not q:
                    print("  Usa: /web <query>")
                    continue
                print(f"  {C['y']}🔍 Cerco: {q}{C['re']}")
                print(f"\n{web_search(q)}")
                continue

            elif cl.startswith("cat") or cl.startswith("read"):
                path = cmd[3:].strip() if cl.startswith("cat") else cmd[4:].strip()
                if not path:
                    print("  Usa: /cat <file>")
                    continue
                print(f"  {C['y']}📄 Leggo: {path}{C['re']}")
                result = read_file(path)
                if result.startswith("❌"):
                    print(f"\n  {result}")
                else:
                    print(f"\n{C['gray']}{result}{C['re']}")
                continue

            elif cl.startswith("sys") or cl == "system":
                parts = cmd.split()
                cat = parts[1] if len(parts) > 1 else "all"
                print(f"  {C['y']}📊 Stato sistema...{C['re']}")
                print(f"\n{system_info(cat)}")
                continue

            elif cl == "model":
                models = list_models()
                if not models:
                    print(f"  {C['r']}❌ Impossibile contattare il motore.{C['re']}")
                    continue
                current = MODEL
                print(f"\n  {C['b']}Modelli disponibili:{C['re']}")
                for m in models:
                    marker = f"{C['g']}← attivo{C['re']}" if m == current else ""
                    print(f"    {m:45s} {marker}")
                print(f"\n  {C['d']}Per cambiare: riavvia aria e scegli dal menu, o ARIA_MODEL=<nome> aria{C['re']}")
                continue

            elif cl == "think":
                show_reasoning = not show_reasoning
                state = f"{C['g']}ON{C['re']}" if show_reasoning else f"{C['r']}OFF{C['re']}"
                print(f"  Pensiero visibile: {state}")
                continue

            else:
                print(f"  Comando sconosciuto. /help per l'elenco.")
                continue

        # ── Chat normale ──
        messages.append({"role": "user", "content": user_input})

        # Piccola pausa per leggibilità
        print()

        # Ciclo tool calling + risposta finale in streaming
        tool_rounds = 0
        content_acc = ""
        _visible_len = 0
        reasoning_acc = ""
        reasoning_header_shown = False
        final_usage = {}
        final_timings = {}
        done_final = False

        while tool_rounds < 5 and not done_final:
            tool_rounds += 1

            # Stream della risposta
            for event in call_llm_stream(messages, tools=TOOLS):

                # ── Errore ──
                if event["type"] == "error":
                    if event["text"] == "connection_refused":
                        print(f"\r  {C['r']}❌ Motore non raggiungibile.{C['re']}")
                    else:
                        print(f"\r  {C['r']}❌ {event['text']}{C['re']}")
                    # Rimuovi il messaggio utente che ha causato l'errore
                    # (solo se è ancora in coda — il while loop potrebbe averlo già rimosso)
                    if messages and messages[-1]["role"] == "user":
                        messages.pop()
                    content_acc = ""
                    _visible_len = 0
                    done_final = True  # Esci dal while loop, non ritentare su errori server
                    break

                # ── Reasoning in tempo reale (a capo naturale, toggle con /think) ──
                elif event["type"] == "reasoning":
                    reasoning_acc += event["text"]
                    if show_reasoning:
                        # Primo token: stampa l'header
                        if not reasoning_header_shown:
                            print(f"  {C['gray']}🧠{C['re']} ", end="", flush=True)
                            reasoning_header_shown = True
                        # Token successivi: append normale, il terminale wrappa da sé
                        print(f"{C['gray']}{event['text']}{C['re']}", end="", flush=True)

                # ── Contenuto in tempo reale ──
                elif event["type"] == "content":
                    # Prima parola: separa dal pensiero con una riga vuota
                    if not content_acc and reasoning_header_shown:
                        print()
                    prev_visible = _visible_len
                    content_acc += event["text"]
                    # Filtra tag  response/ che i modelli Qwen-based
                    # emettono come testo anche senza thinking reale.
                    # Primo pass: rimuovi blocchi completi.
                    # Secondo pass: rimuovi tag orfani (non ancora chiusi in streaming).
                    clean = re.sub(r'\s*<think>.*?</think>\s*', ' ', content_acc, flags=re.DOTALL)
                    clean = re.sub(r'</?think>', '', clean)
                    clean = clean.strip()
                    new_visible = clean[prev_visible:]
                    if new_visible:
                        print(new_visible, end="", flush=True)
                        _visible_len = len(clean)

                # ── Fine ──
                elif event["type"] == "done":
                    final_reason = event["reason"]
                    final_usage = event.get("usage", {})
                    final_timings = event.get("timings", {})

                    # Se ci sono tool call da eseguire
                    tcs = event.get("tool_calls")
                    if tcs and final_reason == "tool_calls":
                        print()
                        msg = {
                            "role": "assistant",
                            "content": content_acc,
                            "tool_calls": [
                                {"type": "function", "id": tc["id"],
                                 "function": {"name": tc["name"], "arguments": tc["arguments"]}}
                                for tc in tcs
                            ]
                        }
                        messages.append(msg)
                        for tc in tcs:
                            name = tc["name"]
                            try:
                                args = json.loads(tc["arguments"])
                            except (json.JSONDecodeError, TypeError):
                                args = {}
                            print(f"  {C['y']}🔧 {name} {C['re']}{json.dumps(args, ensure_ascii=False)}")
                            tool_result = run_tool(name, args)
                            messages.append({"role": "tool", "tool_call_id": tc["id"], "content": tool_result})
                        content_acc = ""
                        _visible_len = 0
                        reasoning_acc = ""
                        break  # for loop → while loop → next round

                    # ── Risposta finale ──
                    if content_acc or reasoning_acc:
                        print()
                        n_input = final_usage.get("prompt_tokens", 0)
                        n_output = final_usage.get("completion_tokens", 0)
                        n_total = final_usage.get("total_tokens", 0)
                        tps = final_timings.get("predicted_per_second", 0)
                        pps = final_timings.get("prompt_per_second", 0)

                        stats = []
                        if n_total:
                            stats.append(f"{n_total} token")
                        if pps:
                            stats.append(f"{pps:.0f} t/s pp")
                        if tps:
                            stats.append(f"{tps:.1f} t/s tg")
                        if "prompt_tokens_details" in final_usage:
                            cached = final_usage["prompt_tokens_details"].get("cached_tokens", 0)
                            if cached:
                                stats.append(f"{cached} cached")
                        if stats:
                            print(f"  {C['d']}{' · '.join(stats)}{C['re']}")

                    messages.append({"role": "assistant", "content": content_acc})
                    done_final = True
                    break  # for loop

            else:
                # Il for loop è terminato senza break:
                # lo stream non ha emesso né un evento 'done' né un errore.
                # Salviamo il contenuto parziale e usciamo.
                if content_acc:
                    messages.append({"role": "assistant", "content": content_acc})
                break  # while loop

        save_history(messages[-100:])

    # Saluta
    bye = random.choice(EXIT_MSGS)
    line = random.choice(PARTY_LINES)
    print(f"\n  {C['d']}{bye}{C['re']}")
    print(f"  {C['d']}{line}{C['re']}\n")


if __name__ == "__main__":
    # SIGINT (Ctrl+C), SIGTERM (kill), SIGHUP (terminale chiuso)
    # → sys.exit(0) — il server gestisce lo scarico modelli via stop-timeout
    for sig in (signal.SIGINT, signal.SIGTERM, signal.SIGHUP):
        signal.signal(sig, lambda s, f: sys.exit(0))
    chat_loop()
