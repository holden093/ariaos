#!/bin/bash
set -e

# Verifica esecuzione come root
if [ "$EUID" -ne 0 ]; then
  echo "Questo script deve essere eseguito come root (es. sudo nixitos-home-restore)."
  exit 1
fi

# Verifica dipendenze
for cmd in btrfs dialog zstd pv lsblk; do
  if ! command -v $cmd &> /dev/null; then
    echo "Errore: comando richiesto '$cmd' non trovato. Assicurati che sia installato."
    exit 1
  fi
done

# Trova partizioni potenzialmente usabili (esclude quelle di sistema)
partitions=$(lsblk -rn -o NAME,FSTYPE,MOUNTPOINT,SIZE | awk '$2 != "" && $2 != "swap" && $2 != "vfat" && $2 != "efi" && $3 != "/" && $3 != "/boot" && $3 != "/var" && $3 != "[SWAP]" {print $1, $2, $4, $3}')

if [ -z "$partitions" ]; then
  dialog --msgbox "Nessuna partizione esterna valida trovata.\nAssicurati di aver collegato il disco USB con il backup." 8 60
  exit 1
fi

# Menu
menu_options=()
while read -r name fstype size mountpoint; do
  desc="$fstype - $size"
  if [ -n "$mountpoint" ]; then
    desc="$desc (Montato in $mountpoint)"
  else
    desc="$desc (Non montato)"
  fi
  menu_options+=("/dev/$name" "$desc")
done <<< "$partitions"

TARGET_DEV=$(dialog --clear --title "NixitOS - Restore Home" \
        --menu "Scegli la partizione contenente il backup:" 15 70 6 \
        "${menu_options[@]}" \
        3>&1 1>&2 2>&3)

if [ -z "$TARGET_DEV" ]; then
  clear
  echo "Operazione annullata dall'utente."
  exit 0
fi

# Gestione mount
MOUNT_POINT=$(lsblk -rn -o MOUNTPOINT "$TARGET_DEV")
TEMP_MOUNT=0

if [ -z "$MOUNT_POINT" ]; then
  MOUNT_POINT=$(mktemp -d /tmp/nixitos-restore-mnt.XXXXXX)
  if ! mount "$TARGET_DEV" "$MOUNT_POINT"; then
    dialog --msgbox "Impossibile montare $TARGET_DEV." 8 50
    rm -rf "$MOUNT_POINT"
    exit 1
  fi
  TEMP_MOUNT=1
fi

BACKUP_FILE="$MOUNT_POINT/nixitos_home.btrfs.zst"

if [ ! -f "$BACKUP_FILE" ]; then
  dialog --msgbox "File di backup non trovato!\nNessun file in: $BACKUP_FILE" 8 60
  [ $TEMP_MOUNT -eq 1 ] && umount "$MOUNT_POINT" && rm -rf "$MOUNT_POINT"
  exit 1
fi

# Verifica distruttiva
dialog --yesno "ATTENZIONE!\nQuesta operazione sovrascriverà l'attuale cartella /var/home con il backup.\n\nSei sicuro di voler procedere?" 10 60
if [ $? -ne 0 ]; then
  [ $TEMP_MOUNT -eq 1 ] && umount "$MOUNT_POINT" && rm -rf "$MOUNT_POINT"
  clear
  echo "Operazione annullata."
  exit 0
fi

clear
echo "========================================================="
echo " Importazione Backup Home (Zstd -> Btrfs Receive)"
echo " Sorgente: $BACKUP_FILE"
echo "========================================================="
echo "Attendere il completamento dell'operazione..."

# Rimuovi vecchio restore pendente se presente
btrfs subvolume delete /var/home-backup >/dev/null 2>&1 || true

set -o pipefail
# Usa pv per mostrare il progresso della decompressione
if zstdcat "$BACKUP_FILE" | pv -brt | btrfs receive /var/ >/dev/null; then
  echo ""
  echo "✅ Flusso ricevuto con successo. Preparazione della nuova home..."
else
  echo ""
  echo "❌ Errore durante l'importazione del backup."
  dialog --msgbox "Si è verificato un errore durante l'importazione (btrfs receive fallito)." 8 50
  [ $TEMP_MOUNT -eq 1 ] && umount "$MOUNT_POINT" && rm -rf "$MOUNT_POINT"
  exit 1
fi
set +o pipefail

# Swap della home
echo "Sostituzione dell'attuale /var/home con quella ripristinata..."

# Se /var/home è un subvolume vuoto generato dalla reinstallazione, lo cancelliamo
if btrfs subvolume show /var/home &> /dev/null; then
  btrfs subvolume delete /var/home >/dev/null 2>&1
else
  mv /var/home /var/home.old_$(date +%s) >/dev/null 2>&1 || true
fi

# La snapshot ricevuta è read-only, facciamo uno snapshot RW
if ! btrfs subvolume snapshot /var/home-backup /var/home >/dev/null 2>&1; then
   echo "❌ Impossibile rendere read-write la home. Il sistema potrebbe essere in uno stato inconsistente."
   exit 1
fi

# Pulizia
btrfs subvolume delete /var/home-backup >/dev/null 2>&1 || true

if [ $TEMP_MOUNT -eq 1 ]; then
  echo "Smontaggio disco in corso..."
  umount "$MOUNT_POINT"
  rm -rf "$MOUNT_POINT"
fi

dialog --msgbox "Ripristino completato con successo!\n\nÈ necessario riavviare il sistema affinché tutte le applicazioni e i servizi leggano la nuova home." 10 60

clear
echo "========================================================="
echo "✅ Ripristino completato con successo!"
echo "   Per favore riavvia il sistema."
echo "========================================================="
