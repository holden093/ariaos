#!/bin/bash
set -e

# Verifica esecuzione come root
if [ "$EUID" -ne 0 ]; then
  echo "Questo script deve essere eseguito come root (es. sudo nixitos-home-backup)."
  exit 1
fi

# Verifica dipendenze
for cmd in btrfs dialog zstd pv lsblk; do
  if ! command -v $cmd &> /dev/null; then
    echo "Errore: comando richiesto '$cmd' non trovato. Assicurati che sia installato."
    exit 1
  fi
done

# Verifica che /var/home sia un subvolume btrfs
if ! btrfs subvolume show /var/home &> /dev/null; then
  dialog --msgbox "Errore: /var/home non risulta essere un subvolume Btrfs valido." 8 50
  exit 1
fi

# Trova partizioni potenzialmente usabili (esclude quelle di sistema)
partitions=$(lsblk -rn -o NAME,FSTYPE,MOUNTPOINT,SIZE | awk '$2 != "" && $2 != "swap" && $2 != "vfat" && $2 != "efi" && $3 != "/" && $3 != "/boot" && $3 != "/var" && $3 != "[SWAP]" {print $1, $2, $4, $3}')

if [ -z "$partitions" ]; then
  dialog --msgbox "Nessuna partizione esterna valida (ext4/btrfs/exfat) trovata.\nAssicurati di aver collegato un disco USB." 8 60
  exit 1
fi

# Costruisci le opzioni per il menu dialog
menu_options=()
while read -r name fstype size mountpoint; do
  desc="$fstype - $size"
  if [ -n "$mountpoint" ]; then
    desc="$desc (Montato in $mountpoint)"
  else
    desc="$desc (Non montato)"
  fi
  menu_options+=("/dev/$name" "$desc")
done <<< "$partitions"

# Mostra il menu
TARGET_DEV=$(dialog --clear --title "NixitOS - Backup Home" \
        --menu "Scegli la partizione di destinazione per il backup:" 15 70 6 \
        "${menu_options[@]}" \
        3>&1 1>&2 2>&3)

if [ -z "$TARGET_DEV" ]; then
  clear
  echo "Operazione annullata dall'utente."
  exit 0
fi

# Gestione mount
MOUNT_POINT=$(lsblk -rn -o MOUNTPOINT "$TARGET_DEV")
TEMP_MOUNT=0

if [ -z "$MOUNT_POINT" ]; then
  MOUNT_POINT=$(mktemp -d /tmp/nixitos-backup-mnt.XXXXXX)
  if ! mount "$TARGET_DEV" "$MOUNT_POINT"; then
    dialog --msgbox "Impossibile montare $TARGET_DEV." 8 50
    rm -rf "$MOUNT_POINT"
    exit 1
  fi
  TEMP_MOUNT=1
fi

BACKUP_FILE="$MOUNT_POINT/nixitos_home.btrfs.zst"

if [ -f "$BACKUP_FILE" ]; then
  dialog --yesno "Il file $BACKUP_FILE esiste già.\nVuoi sovrascriverlo?" 8 60
  response=$?
  if [ $response -ne 0 ]; then
    [ $TEMP_MOUNT -eq 1 ] && umount "$MOUNT_POINT" && rm -rf "$MOUNT_POINT"
    clear
    echo "Operazione annullata."
    exit 0
  fi
fi

# Avviso e preparazione snapshot
dialog --infobox "Creazione snapshot read-only in corso..." 5 50
btrfs subvolume delete /var/home-backup &> /dev/null || true

if ! btrfs subvolume snapshot -r /var/home /var/home-backup >/dev/null 2>&1; then
   dialog --msgbox "Impossibile creare la snapshot /var/home-backup." 8 50
   [ $TEMP_MOUNT -eq 1 ] && umount "$MOUNT_POINT" && rm -rf "$MOUNT_POINT"
   exit 1
fi

# Esportazione
clear
echo "========================================================="
echo " Esportazione e Compressione Backup Home (Btrfs -> Zstd)"
echo " Destinazione: $BACKUP_FILE"
echo "========================================================="
echo "Attendere il completamento dell'operazione..."

set -o pipefail
# pv -brt mostra byte trasferiti, rate e tempo trascorso
if btrfs send /var/home-backup 2>/dev/null | pv -brt | zstd -T0 > "$BACKUP_FILE"; then
  clear
  echo "========================================================="
  echo "✅ Backup completato con successo!"
  echo "File salvato in: $BACKUP_FILE"
  echo "========================================================="
  dialog --msgbox "Backup completato con successo!\nFile: $BACKUP_FILE" 8 60
else
  clear
  echo "❌ Errore durante l'esportazione del backup."
  dialog --msgbox "Si è verificato un errore durante l'esportazione." 8 50
fi
set +o pipefail

# Pulizia
echo "Rimozione snapshot temporanea..."
btrfs subvolume delete /var/home-backup >/dev/null 2>&1

if [ $TEMP_MOUNT -eq 1 ]; then
  echo "Smontaggio disco in corso..."
  umount "$MOUNT_POINT"
  rm -rf "$MOUNT_POINT"
  echo "Disco $TARGET_DEV smontato in sicurezza."
fi

echo "Operazione conclusa."
